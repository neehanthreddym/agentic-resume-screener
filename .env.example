# ============================================================
# .env.example — AI-Powered Resume Screener
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM API Keys ---
# Primary: Groq (free tier — llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key_here

# Fallback: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# --- Model Configuration ---
PRIMARY_MODEL=llama-3.3-70b-versatile
FALLBACK_MODEL=gpt-4o-mini
PRIMARY_PROVIDER=groq   # groq | openai

# --- Application Settings ---
APP_ENV=development     # development | production
LOG_LEVEL=INFO

# --- FastAPI Settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Optional: LangSmith Tracing (free tier) ---
# Uncomment to enable LangSmith experiment tracking
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=agentic-resume-screener