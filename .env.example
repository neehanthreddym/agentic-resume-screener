# ============================================================
# .env.example — AI-Powered Resume Screener
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Provider Selection ---
# Active provider: "groq" (default) or "google"
LLM_PROVIDER=groq

# --- Groq (default provider) ---
# Free tier: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# override Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (native google-genai SDK) ---
GOOGLE_API_KEY=your_google_api_key_here
# override Gemini model (default: gemini-2.0-flash)
GOOGLE_MODEL=gemini-2.0-flash

# --- Application Settings ---
APP_ENV=development     # development | production
LOG_LEVEL=INFO

# --- FastAPI Settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Optional: LangSmith Tracing (free tier) ---
# Uncomment to enable LangSmith experiment tracking
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=agentic-resume-screener